{
    "name": "Qt6 QML Dev Environment",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-vscode.cpptools",
                "ms-vscode.cmake-tools",
                "twxs.cmake"
            ]
        }
    },
    "forwardPorts": [
        8080
    ],
    "runArgs": [
        "--net=host",
        "-e",
        "DISPLAY=${env:DISPLAY}",
        "-v",
        "/tmp/.X11-unix:/tmp/.X11-unix"
    ],
    "containerEnv": {
        "QT_X11_NO_MITSHM": "1"
    }
}